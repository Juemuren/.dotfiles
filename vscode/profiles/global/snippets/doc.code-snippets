{
  "markdown-table-pipe": {
    "scope": "markdown",
    "prefix": ["table", "||"],
    "body": [
      "| $1 | $2 |",
      "|----|----|",
      "| $3 | $4 |",
      "$0"
    ],
    "description": "Markdown pipe table"
  },
  "markdown-math-block": {
    "scope": "markdown",
    "prefix": ["math", "$$"],
    "body": [
      "$$",
      "$1",
      "$$",
      "$0"
    ],
    "description": "Markdown math block"
  },
  "markdown-code-block": {
    "scope": "markdown",
    "prefix": ["code", "``"],
    "body": [
      "```${1:language}",
      "$2",
      "```",
      "$0"
    ],
    "description": "Markdown code block"
  },
  "latex-derivative": {
    "scope": "latex",
    "prefix": "derivative",
    "body": "\\frac{\\mathrm{d}${1:y}}{\\mathrm{d}${2:x}} $0",
    "description": "LaTeX derivative"
  },
  "latex-partial-derivative": {
    "scope": "latex",
    "prefix": "partial-derivative",
    "body": "\\frac{\\partial ${1:y}}{\\partial ${2:x}} $0",
    "description": "LaTeX partial derivative"
  },
  "latex-integration": {
    "scope": "latex",
    "prefix": "integration",
    "body": "\\int_{${1:a}}^{${2:b}} ${4:f} \\mathrm{d}${3:x} $0",
    "description": "LaTeX integration"
  },
  "latex-differentiation": {
    "scope": "latex",
    "prefix": "differentiation",
    "body": "\\mathrm{d}${1:y} = ${3:f} \\mathrm{d}${2:x} $0",
    "description": "LaTeX differentiation"
  },
  "latex-jacobian-matrix": {
    "scope": "latex",
    "prefix": "jacobian-matrix",
    "body": [
      "\\begin{bmatrix}",
      "  \\frac{\\partial ${1:x}}{\\partial ${3:u}} & \\frac{\\partial ${1:x}}{\\partial ${4:v}} \\\\\\",
      "  \\frac{\\partial ${2:y}}{\\partial ${3:u}} & \\frac{\\partial ${2:y}}{\\partial ${4:v}}",
      "\\end{bmatrix}",
      "$0"
    ],
    "description": "LaTeX jacobian matrix"
  },
  "latex-jacobian-determinant": {
    "scope": "latex",
    "prefix": "jacobian-determinant",
    "body": [
      "\\begin{vmatrix}",
      "  \\frac{\\partial ${1:x}}{\\partial ${3:u}} & \\frac{\\partial ${1:x}}{\\partial ${4:v}} \\\\\\",
      "  \\frac{\\partial ${2:y}}{\\partial ${3:u}} & \\frac{\\partial ${2:y}}{\\partial ${4:v}}",
      "\\end{vmatrix}",
      "$0"
    ],
    "description": "LaTeX jacobian determinant"
  },
  "latex-hessian-matrix": {
    "scope": "latex",
    "prefix": "hessian-matrix",
    "body": [
      "\\begin{bmatrix}",
      "  \\frac{\\partial^2 ${1:f}}{\\partial ${2:x}^2} & \\frac{\\partial^2 ${1:f}}{\\partial ${2:x}\\partial ${3:y}} \\\\\\",
      "  \\frac{\\partial^2 ${1:f}}{\\partial ${3:y}\\partial ${2:x}} & \\frac{\\partial^2 ${1:f}}{\\partial ${3:y}^2}",
      "\\end{bmatrix}",
      "$0"
    ],
    "description": "LaTeX hessian matrix"
  },
  "latex-hessian-determinant": {
    "scope": "latex",
    "prefix": "hessian-determinant",
    "body": [
      "\\begin{vmatrix}",
      "  \\frac{\\partial^2 ${1:f}}{\\partial ${2:x}^2} & \\frac{\\partial^2 ${1:f}}{\\partial ${2:x}\\partial ${3:y}} \\\\\\",
      "  \\frac{\\partial^2 ${1:f}}{\\partial ${3:y}\\partial ${2:x}} & \\frac{\\partial^2 ${1:f}}{\\partial ${3:y}^2}",
      "\\end{vmatrix}",
      "$0"
    ],
    "description": "LaTeX hessian determinant"
  }
}
