root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{sh,bash,ps1}]
indent_size = 4

[Justfile]
indent_size = 4

[wt/wt.json]
trim_trailing_whitespace = false
insert_final_newline = false
indent_size = 4

[fastfetch/sakiko.txt]
insert_final_newline = false
